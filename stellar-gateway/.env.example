# Stellar x402 Gateway Configuration

# Port for the gateway server
PORT=3402

# Stellar address to receive payments (your public key, starts with G)
STELLAR_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenZeppelin Channels API key
# Generate at: https://channels.openzeppelin.com/testnet/gen (testnet)
# Generate at: https://channels.openzeppelin.com/gen (mainnet)
OPENZEPPELIN_API_KEY=your_api_key_here

# Network: "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Upstream risk engine URL (the Python FastAPI server)
UPSTREAM_URL=http://localhost:8402
